# Database
DATABASE_URL=postgresql://user:password@localhost:5432/chainguard

# API
PORT=8080
DASHBOARD_INGEST_KEY=your-secret-ingest-key

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:8080/api/auth/callback
SESSION_KEY=your-super-secret-session-key-change-in-production

# Restrict access to specific GitHub usernames (comma-separated, empty allows all)
GITHUB_ALLOWED_USERS=TripleAze
